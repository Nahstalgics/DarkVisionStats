QWidget {
    background-color: #101010;
}
QLabel {
    color: #F2673A;
    font-size: 24px;
    font-family: 'Segoe UI', sans-serif;
    font-weight: bold;
}
QPushButton {
    background-color: #000000;
    color: white;
    border-radius: 6px;
    font-size: 16px;
    padding: 10px 20px;
    border: 1px solid transparent;
}
QPushButton:hover {
    background-color: #101010;
    padding: 12px 24px;
    font-size: 17px;
    border: 1px solid #F2673A;
}